../*
# ====================================================================
# 1. LOCAL HISTORY & EDITORS (Thư mục lịch sử & IDEs)
# ====================================================================
.history/
../.history/
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================================================
# 2. LOGS & DIAGNOSTICS (File nhật ký hệ thống và lỗi)
# ====================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ====================================================================
# 3. DEPENDENCIES & PACKAGES (Thư mục thư viện cài đặt)
# ====================================================================
node_modules/
jspm_packages/
web_modules/
bower_components/
.pnpm-store

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ====================================================================
# 4. BUILD OUTPUTS & CACHES (Sản phẩm sau khi Build và Caches)
# ====================================================================
dist
dist-ssr
out
.output
build/Release
.cache
.parcel-cache
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.node_repl_history
*.tgz
.yarn-integrity

# Next.js / Nuxt.js / Gatsby / Sveltekit / Vite
.next
.nuxt
.cache/
.vuepress/dist
.temp
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ====================================================================
# 5. ENVIRONMENT VARIABLES (File chứa mật khẩu, key bí mật - CẦN CHẶN)
# ====================================================================
.env
.env.*
*.local
!.env.example

